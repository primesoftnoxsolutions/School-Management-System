PORT=5000

# Local MongoDB (uncomment for local development)
MONGODB_URI=mongodb://127.0.0.1:27017/school_erp

# Live MongoDB Atlas (uncomment for production / live database)
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/school_erp?retryWrites=true&w=majority

SESSION_SECRET=replace_with_secure_session_secret

# Super Admin — required on LIVE/production (optional locally; dev defaults apply)
# SEED_ADMIN_EMAIL=admin@yourdomain.com
# SEED_ADMIN_PASSWORD=YourSecurePassword123
# SEED_ADMIN_NAME=Super Admin

# Local dev defaults (when SEED_* not set, NODE_ENV != production):
#   Email:    admin@schoolerp.local
#   Password: Admin@123
